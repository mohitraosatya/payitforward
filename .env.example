# Copy this file to .env and fill in the value.
# NEVER commit .env to git — it contains your Apps Script URL.

# The base URL of your deployed Google Apps Script Web App.
# Example: https://script.google.com/macros/s/AKfycb.../exec
VITE_API_BASE_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
